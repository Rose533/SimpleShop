@{
    ViewData["Title"] = "管理後台儀表板";
}

<h1>@ViewData["Title"]</h1>

<div class="row mt-4">
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h5>商品總數</h5>
                <h2>@ViewBag.ProductCount</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h5>訂單總數</h5>
                <h2>@ViewBag.OrderCount</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h5>待處理訂單</h5>
                <h2>@ViewBag.PendingOrderCount</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h5>今日營收</h5>
                <h2>NT$@ViewBag.TodayRevenue</h2>
            </div>
        </div>
    </div>
</div>

<hr />

<div class="row mt-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">商品管理</h5>
                <p class="card-text">新增、編輯或刪除商品。</p>
                <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="btn btn-primary">
                    前往商品管理
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">訂單管理</h5>
                <p class="card-text">查看訂單詳情並處理出貨。</p>
                <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="btn btn-primary">
                    前往訂單管理
                </a>
            </div>
        </div>
    </div>
</div>

